  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 3961fb74196f2a44a837ac22e48280d4, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  avatarSprite: {fileID: 21300000, guid: 8ef80ca11fe0be54bb14d1e0a5d3a35d, type: 3}
  promptText: Press Enter to Talk
  textHeight: 0.5
  fontAsset: {fileID: 11400000, guid: 358d097249919594790a24b77037a3b0, type: 2}
  canGiveSkillPoints: 1
  triggersSceneTransition: 1
  nextSceneName: SampleScene 1
  transitionDelay: 0.5
  bounceAmplitude: 0.02
  bounceSpeed: 3
  dialogueLines:
  - You made it out.
  - "Most things that go past those ruins don\u2019t."
  - "Your readings stabilized. Not perfect\u2026 but better than before."
  - Looks like you spent those control nodes wisely.
  - "The caves ahead aren\u2019t like the surface."
  - Signal interference. Narrow paths. No room to recover if you mess up.
  - Your dash will be useful down there.
  - So will knowing when not to use it.
  - "Creatures in the caves don\u2019t rush."
  - They wait.
  - "And some of them don\u2019t show up on sensors at all."
  - "If your two forms fall out of sync in there\u2026"
  - "\u2026you won\u2019t get a second chance to correct it."
  - Last chance to prepare.
  - "Once you drop in, you\u2019re committed."
  - "If the interference clears, I\u2019ll find you again."
  npcAudioClips: []
